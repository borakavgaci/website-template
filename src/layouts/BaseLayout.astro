---
import "../styles/global.css";
import type { SiteConfig } from "../types/site";

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const cssVars = [
  `--primary:${site.theme.primary}`,
  `--secondary:${site.theme.secondary}`,
  `--accent:${site.theme.accent}`,
  `--background:${site.theme.background}`,
  `--surface:${site.theme.surface}`,
  `--text:${site.theme.text}`,
  `--muted:${site.theme.muted}`
].join(";");
---

<!doctype html>
<html lang="tr" style={cssVars}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={site.seo.description} />
    <meta property="og:title" content={site.seo.title} />
    <meta property="og:description" content={site.seo.description} />
    <meta property="og:type" content="website" />
    <title>{site.seo.title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
