---
import type { SiteConfig } from "../types/site";

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const navItems = site.navigation.filter((item) => item.enabled);
---

<header class="site-header">
  <a class="brand" href="#anasayfa" aria-label={`${site.business.name} ana sayfa`}>
    <span class="brand-mark">{site.business.logoText}</span>
    <span>
      <strong>{site.business.name}</strong>
      <small>{site.business.sector}</small>
    </span>
  </a>
  <nav class="site-nav" aria-label="Ana menü">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <details class="mobile-menu">
    <summary aria-label="Menüyü aç">
      <span></span>
      <span></span>
      <span></span>
    </summary>
    <nav aria-label="Mobil menü">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </details>
  <a class="header-action" href={`https://wa.me/${site.business.whatsapp}`}>Randevu</a>
</header>

<script>
  const header = document.querySelector(".site-header");

  function updateHeaderHeight() {
    const headerHeight = header?.getBoundingClientRect().height ?? 0;
    document.documentElement.style.setProperty("--header-height", `${Math.ceil(headerHeight)}px`);
  }

  function getHashTarget(hash: string) {
    if (!hash.startsWith("#")) {
      return null;
    }

    return document.getElementById(decodeURIComponent(hash.slice(1)));
  }

  function scrollToHash(hash: string, behavior: ScrollBehavior = "smooth") {
    const target = getHashTarget(hash);

    if (!target) {
      return;
    }

    const headerHeight = header?.getBoundingClientRect().height ?? 0;
    const targetTop = target.getBoundingClientRect().top + window.scrollY - headerHeight;

    window.scrollTo({
      top: Math.max(targetTop, 0),
      behavior
    });
  }

  updateHeaderHeight();

  if (header) {
    new ResizeObserver(updateHeaderHeight).observe(header);
  }

  window.addEventListener("resize", updateHeaderHeight);

  document.querySelectorAll<HTMLAnchorElement>(".site-header a[href^='#']").forEach((link) => {
    link.addEventListener("click", (event) => {
      const href = link.getAttribute("href");

      if (!href || !getHashTarget(href)) {
        return;
      }

      event.preventDefault();
      link.closest("details")?.removeAttribute("open");
      history.pushState(null, "", href);
      scrollToHash(href);
    });
  });

  window.addEventListener("load", () => {
    updateHeaderHeight();

    if (window.location.hash) {
      window.setTimeout(() => scrollToHash(window.location.hash, "auto"), 0);
    }
  });
</script>
